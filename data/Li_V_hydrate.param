comment              : geo opt
task                 : geometry optimisation
xc_functional        : RSCAN
opt_strategy         : Speed
cut_off_energy       : 850 eV
fix_occupancy        : true
geom_force_tol       : 0.005 ev/ang
elec_energy_tol      : 0.0000000001 eV
elec_method          : dm
geom_method          : BFGS
nextra_bands         : 40
max_scf_cycles       : 300
geom_max_iter        : 300
write_cell_structure : true
calculate_hirshfeld  : true
